---
// FinalCTA.astro — full-width call-to-action before footer
const baseUrl = import.meta.env.BASE_URL;
---

<section class="relative bg-surface-raised py-24">
  <!-- Gradient top border -->
  <div class="absolute left-0 right-0 top-0 h-px bg-gradient-to-r from-transparent via-accent-purple/30 to-transparent"></div>

  <div class="mx-auto max-w-3xl px-6 text-center">
    <h2 class="text-3xl font-extrabold text-text-primary md:text-4xl">
      Ready to own your meetings?
    </h2>
    <p class="mt-4 text-text-secondary">
      Free. Private. Open source. Download NexQ and take control.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <a
        href="https://github.com/VahidAlizadeh/NexQ/releases/latest"
        class="btn-primary"
      >
        Download for Windows
      </a>
      <a
        href="https://github.com/VahidAlizadeh/NexQ"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary"
      >
        Star on GitHub
      </a>
    </div>
  </div>
</section>
