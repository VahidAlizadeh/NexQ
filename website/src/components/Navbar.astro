---
const baseUrl = import.meta.env.BASE_URL;
const navLinks = [
  { label: 'Features', href: '#features' },
  { label: 'Use Cases', href: '#use-cases' },
  { label: 'Compare', href: '#compare' },
  { label: 'Docs', href: '#docs' },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 h-16 transition-colors duration-300"
>
  <div class="mx-auto flex h-full max-w-6xl items-center justify-between px-6">
    <!-- Left: Logo + Name -->
    <a href={baseUrl} class="flex items-center gap-2.5 text-text-primary">
      <img
        src={`${baseUrl}nexq-logo.png`}
        alt="NexQ"
        width="32"
        height="32"
        class="rounded-lg"
      />
      <span class="text-lg font-bold tracking-tight">NexQ</span>
    </a>

    <!-- Center: Nav Links (hidden on mobile) -->
    <div class="hidden items-center gap-1 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="rounded-md px-3 py-1.5 text-sm font-medium text-text-secondary transition-colors duration-150 hover:text-text-primary"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Right: GitHub Stars + Download -->
    <div class="flex items-center gap-3">
      <a
        href="https://github.com/VahidAlizadeh/NexQ"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden items-center gap-1.5 rounded-md px-2 py-1 text-text-secondary transition-colors duration-150 hover:text-text-primary sm:flex"
        aria-label="NexQ on GitHub"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
        <img
          src="https://img.shields.io/github/stars/VahidAlizadeh/NexQ?style=flat&label=&color=333&labelColor=333"
          alt="GitHub stars"
          class="h-5"
          loading="lazy"
        />
      </a>
      <a
        href="https://github.com/VahidAlizadeh/NexQ/releases/latest"
        class="btn-primary !px-4 !py-2 !text-xs"
      >
        Download
      </a>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  if (navbar) {
    const scrollClasses = [
      'bg-surface/80',
      'backdrop-blur-xl',
      'border-b',
      'border-white/5',
    ];

    // Use Tailwind's arbitrary opacity via inline style for bg
    let scrolled = false;

    function onScroll() {
      const shouldBeScrolled = window.scrollY > 20;
      if (shouldBeScrolled === scrolled) return;
      scrolled = shouldBeScrolled;

      if (scrolled) {
        navbar.style.backgroundColor = 'rgba(12, 12, 20, 0.8)';
        navbar.style.backdropFilter = 'blur(24px)';
        navbar.style.webkitBackdropFilter = 'blur(24px)';
        navbar.style.borderBottom = '1px solid rgba(255, 255, 255, 0.05)';
      } else {
        navbar.style.backgroundColor = '';
        navbar.style.backdropFilter = '';
        navbar.style.webkitBackdropFilter = '';
        navbar.style.borderBottom = '';
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
